{
  "name": "claude-session-visualizer",
  "version": "0.1.0",
  "description": "Live visualization dashboard for Claude Code sessions",
  "license": "MIT",
  "author": "Anay Paul",
  "repository": {
    "type": "git",
    "url": "https://github.com/anaypaul/claude-session-visualizer.git"
  },
  "keywords": ["claude", "claude-code", "visualization", "dashboard", "developer-tools"],
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@xyflow/react": "^12.0.0",
    "chokidar": "^4.0.0",
    "hono": "^4.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.13.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
